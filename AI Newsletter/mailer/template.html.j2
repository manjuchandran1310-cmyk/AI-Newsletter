<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="color-scheme" content="light dark" />
  <meta name="supported-color-schemes" content="light dark" />
  <title>AI Newsletter — {{ date }}</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style>
    @media (prefers-color-scheme: dark) {
      .body-bg    { background-color: #0f0f0f !important; }
      .wrapper    { background-color: #1a1a1a !important; }
      .header-bg  { background-color: #111827 !important; }
      .body-text  { color: #e5e7eb !important; }
      .muted-text { color: #9ca3af !important; }
      .section-label { color: #60a5fa !important; }
      .card-bg    { background-color: #242424 !important; border-color: #333 !important; }
      .top-card   { background-color: #1e3a5f !important; border-color: #2563eb !important; }
      .divider    { border-color: #333 !important; }
      .tag        { background-color: #1f2937 !important; color: #93c5fd !important; }
      .footer-bg  { background-color: #111 !important; }
      .link-color { color: #60a5fa !important; }
    }
  </style>
</head>
<body class="body-bg" style="margin:0;padding:0;background-color:#f3f4f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;">

  <!-- Preheader (hidden) -->
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">
    Your AI briefing for {{ date }} — top picks from across the ecosystem.&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;
  </div>

  <!-- Outer wrapper -->
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f3f4f6;" class="body-bg">
    <tr>
      <td align="center" style="padding:24px 12px;">

        <!-- Inner card — max 600px -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
               style="max-width:600px;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.1);"
               class="wrapper">

          <!-- ═══════════════ HEADER ═══════════════ -->
          <tr>
            <td class="header-bg" style="background-color:#0f172a;padding:32px 40px 28px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <p style="margin:0 0 4px;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#60a5fa;">DAILY BRIEFING</p>
                    <h1 style="margin:0 0 6px;font-size:28px;font-weight:800;color:#f1f5f9;line-height:1.2;">AI Newsletter</h1>
                    <p style="margin:0;font-size:14px;color:#94a3b8;">{{ date }} &nbsp;·&nbsp; What matters in AI today</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ═══════════════ TOP STORY ═══════════════ -->
          {% if top_story %}
          <tr>
            <td style="padding:32px 40px 0;">
              <p class="section-label" style="margin:0 0 12px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#2563eb;">⭐ TOP STORY</p>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                     style="background-color:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;overflow:hidden;" class="top-card">
                <tr>
                  <td style="padding:24px 28px;">
                    <p style="margin:0 0 6px;font-size:11px;font-weight:600;color:#3b82f6;letter-spacing:1px;text-transform:uppercase;">
                      {{ top_story.source }} &nbsp;·&nbsp; Score {{ top_story.relevance_score }}/10
                    </p>
                    <h2 style="margin:0 0 10px;font-size:20px;font-weight:700;color:#0f172a;line-height:1.35;" class="body-text">
                      <a href="{{ top_story.url }}" class="link-color" style="color:#1d4ed8;text-decoration:none;">{{ top_story.title }}</a>
                    </h2>
                    <p style="margin:0 0 12px;font-size:15px;line-height:1.6;color:#374151;" class="body-text">{{ top_story.summary }}</p>
                    <p style="margin:0;padding:10px 14px;background-color:#dbeafe;border-left:3px solid #3b82f6;border-radius:4px;font-size:13px;font-style:italic;color:#1e40af;">
                      💡 {{ top_story.why_it_matters }}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ TRENDING TOPICS ═══════════════ -->
          {% if trending_topics %}
          <tr>
            <td style="padding:28px 40px 0;">
              <p class="section-label" style="margin:0 0 10px;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#7c3aed;">📈 TRENDING THIS WEEK</p>
              <table role="presentation" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  {% for t in trending_topics[:6] %}
                  <td style="padding-right:8px;padding-bottom:8px;">
                    <span class="tag" style="display:inline-block;padding:4px 12px;background-color:#f3f0ff;border-radius:20px;font-size:12px;font-weight:600;color:#6d28d9;">
                      {{ t.topic }}{% if t.article_count %} ({{ t.article_count }}){% endif %}
                    </span>
                  </td>
                  {% endfor %}
                </tr>
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ AI SECTION ═══════════════ -->
          {% if ai_articles %}
          <tr>
            <td style="padding:28px 40px 0;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding-bottom:14px;border-bottom:2px solid #e2e8f0;" class="divider">
                    <p class="section-label" style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#dc2626;">🤖 ARTIFICIAL INTELLIGENCE</p>
                  </td>
                </tr>
                {% for article in ai_articles %}
                <tr>
                  <td class="card-bg" style="padding:18px 0;border-bottom:1px solid #f1f5f9;">
                    <p style="margin:0 0 4px;font-size:11px;color:#6b7280;" class="muted-text">
                      {{ article.source }} &nbsp;·&nbsp;
                      <span style="color:#16a34a;font-weight:600;">{{ article.relevance_score }}/10</span>
                    </p>
                    <h3 style="margin:0 0 6px;font-size:16px;font-weight:600;line-height:1.4;">
                      <a href="{{ article.url }}" style="color:#0f172a;text-decoration:none;" class="body-text link-color">{{ article.title }}</a>
                    </h3>
                    <p style="margin:0 0 6px;font-size:14px;line-height:1.55;color:#4b5563;" class="body-text">{{ article.one_liner }}</p>
                    {% if article.why_it_matters %}
                    <p style="margin:0;font-size:12px;color:#6b7280;font-style:italic;" class="muted-text">→ {{ article.why_it_matters }}</p>
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ PRODUCT SECTION ═══════════════ -->
          {% if product_articles %}
          <tr>
            <td style="padding:28px 40px 0;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding-bottom:14px;border-bottom:2px solid #e2e8f0;" class="divider">
                    <p class="section-label" style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#0891b2;">🛠 PRODUCT & DESIGN</p>
                  </td>
                </tr>
                {% for article in product_articles %}
                <tr>
                  <td style="padding:18px 0;border-bottom:1px solid #f1f5f9;" class="divider">
                    <p style="margin:0 0 4px;font-size:11px;color:#6b7280;" class="muted-text">
                      {{ article.source }} &nbsp;·&nbsp;
                      <span style="color:#16a34a;font-weight:600;">{{ article.relevance_score }}/10</span>
                    </p>
                    <h3 style="margin:0 0 6px;font-size:16px;font-weight:600;line-height:1.4;">
                      <a href="{{ article.url }}" style="color:#0f172a;text-decoration:none;" class="body-text link-color">{{ article.title }}</a>
                    </h3>
                    <p style="margin:0;font-size:14px;line-height:1.55;color:#4b5563;" class="body-text">{{ article.one_liner }}</p>
                  </td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ FUNDING / BUSINESS ═══════════════ -->
          {% if funding_articles %}
          <tr>
            <td style="padding:28px 40px 0;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding-bottom:14px;border-bottom:2px solid #e2e8f0;" class="divider">
                    <p class="section-label" style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#d97706;">💰 FUNDING & BUSINESS</p>
                  </td>
                </tr>
                {% for article in funding_articles %}
                <tr>
                  <td style="padding:18px 0;border-bottom:1px solid #f1f5f9;" class="divider">
                    <p style="margin:0 0 4px;font-size:11px;color:#6b7280;" class="muted-text">{{ article.source }}</p>
                    <h3 style="margin:0 0 6px;font-size:16px;font-weight:600;line-height:1.4;">
                      <a href="{{ article.url }}" style="color:#0f172a;text-decoration:none;" class="body-text link-color">{{ article.title }}</a>
                    </h3>
                    <p style="margin:0;font-size:14px;line-height:1.55;color:#4b5563;" class="body-text">{{ article.one_liner }}</p>
                  </td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ COMMUNITY / HN ═══════════════ -->
          {% if community_articles %}
          <tr>
            <td style="padding:28px 40px 0;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding-bottom:14px;border-bottom:2px solid #e2e8f0;" class="divider">
                    <p class="section-label" style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#ea580c;">🔥 FROM THE COMMUNITY</p>
                  </td>
                </tr>
                {% for article in community_articles %}
                <tr>
                  <td style="padding:16px 0;border-bottom:1px solid #f1f5f9;" class="divider">
                    <h3 style="margin:0 0 4px;font-size:15px;font-weight:600;line-height:1.4;">
                      <a href="{{ article.url }}" style="color:#0f172a;text-decoration:none;" class="body-text link-color">{{ article.title }}</a>
                    </h3>
                    <p style="margin:0;font-size:13px;color:#6b7280;" class="muted-text">{{ article.source }}{% if article.one_liner %} · {{ article.one_liner }}{% endif %}</p>
                  </td>
                </tr>
                {% endfor %}
              </table>
            </td>
          </tr>
          {% endif %}

          <!-- ═══════════════ FOOTER ═══════════════ -->
          <tr>
            <td class="footer-bg" style="background-color:#0f172a;padding:28px 40px;margin-top:32px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="border-top:1px solid #1e293b;padding-top:20px;">
                    <p style="margin:0 0 8px;font-size:13px;color:#94a3b8;line-height:1.6;">
                      You're receiving this because you subscribed to the AI Newsletter.<br />
                      Powered by <strong style="color:#f1f5f9;">Gemini API</strong>,
                      <strong style="color:#f1f5f9;">Neo4j AuraDB</strong> &amp;
                      <strong style="color:#f1f5f9;">Resend</strong>.
                    </p>
                    <p style="margin:0;font-size:12px;color:#64748b;">
                      <a href="mailto:unsubscribe@example.com?subject=unsubscribe" style="color:#60a5fa;text-decoration:underline;">Unsubscribe</a>
                      &nbsp;·&nbsp;
                      <a href="mailto:feedback@example.com" style="color:#60a5fa;text-decoration:underline;">Send feedback</a>
                      &nbsp;·&nbsp; {{ date }}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- /inner card -->

      </td>
    </tr>
  </table>
  <!-- /outer wrapper -->

</body>
</html>
